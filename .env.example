# APP FACTORY VIDEO IA - Environment example

APP_NAME=APP_FACTORY_VIDEO_IA
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=UTC

COMPANY_NAME=AppFactoryChile
COMPANY_CONTACT_EMAIL=appfactorychile@gmail.com

API_HOST=127.0.0.1
API_PORT=8000
API_BASE_URL=http://127.0.0.1:8000
API_VERSION=v1

DATABASE_URL=postgresql://appfactory:change_me@localhost:5432/app_factory_video_ia

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

STORAGE_PROVIDER=local
STORAGE_BUCKET=app-factory-video-ia-local
STORAGE_REGION=local
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

ENABLE_MANUAL_REVIEW=true
ALLOW_AUTO_PUBLISH=false
REQUIRE_OFFICIAL_APIS=true
BLOCK_UNLICENSED_ASSETS=true

LOG_LEVEL=info
